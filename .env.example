# Strava API credentials — see STRAVA_SETUP.md for how to get these.
# Copy this file to `.env` for local development with `vercel dev`.
# In production, set these in Vercel → Project → Settings → Environment Variables.
# NEVER commit the real values (.env is gitignored).

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
